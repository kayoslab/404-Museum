exports[`US-011 · Content modules — snapshot stability > snapshot for seed "Zx9-pQ" 1`] = `"<section class="module-download-panel"><h2>Download</h2><div class="download-content"><p class="download-version">PostPost Web v1.0.0</p><a href="#" class="download-button">Download for Windows</a><h3>System Requirements</h3><ul class="system-requirements"><li>Linux kernel 2.6+</li><li>Pentium III 500 MHz or faster</li><li>Mac OS X 10.4 or later</li><li>.NET Framework 2.0</li><li>Windows 98 / ME / 2000 / XP</li></ul></div></section><section class="module-news-block"><h2>Latest News</h2><ul class="news-list"><li class="news-item"><time>2014-02-07</time><h3>New Regional Office Opening in Frankfurt</h3><p>Your feedback has been instrumental in shaping this release.</p></li><li class="news-item"><time>2015-08-01</time><h3>Server Migration Complete — Thank You for Your Patience</h3><p>Please review the updated documentation for more information.</p></li><li class="news-item"><time>2014-11-26</time><h3>Community Meetup Recap and Photos</h3><p>We are excited to share the latest updates with our community.</p></li></ul></section><section class="module-testimonials"><h2>Testimonials</h2><div class="testimonials-grid"><blockquote class="testimonial-card"><p class="testimonial-quote">"I cannot imagine going back to the old way of doing things."</p><cite>— P. Johansson, Technical Lead</cite></blockquote><blockquote class="testimonial-card"><p class="testimonial-quote">"Finally, software that just works."</p><cite>— R. Nakamura, Freelance Consultant</cite></blockquote></div></section><section class="module-features-grid"><h2>Features</h2><div class="features-grid"><div class="feature-card"><div class="feature-icon">◆</div><h3>Two-Factor Auth</h3><p>Integrate with your favorite tools and services.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Role Management</h3><p>Migrate your existing data with ease.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Multi-User Support</h3><p>Control who can access what.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Smart Filters</h3><p>Keep working even without an internet connection.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Version History</h3><p>Collaborate with your entire team seamlessly.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Auto-Save</h3><p>Personalize your workspace to match your style.</p></div></div></section>"`;

