exports[`US-012 · Abandonment details — snapshot stability > rendered homepage snapshot with abandonment details 1`] = `"<section class="module-news-block"><h2>Neuigkeiten</h2><ul class="news-list"><li class="news-item"><time>2014-08-24</time><h3>Server Migration Complete — Thank You for Your Patience</h3><p>Your feedback has been instrumental in shaping this release.</p></li><li class="news-item"><time>2011-02-09</time><h3>Security Update: Please Change Your Password</h3><p>This change affects all users on the standard plan.</p></li><li class="news-item"><time>2013-12-25</time><h3>Annual User Survey Results Published</h3><p>Early access is available to all registered members.</p></li><li class="news-item"><time>2012-03-16</time><h3>Mobile App Update Available on All Platforms</h3><p>Read on for full details and instructions.</p></li><li class="news-item"><time>2011-12-21</time><h3>Version 3.0 Released with Major Performance Improvements</h3><p>Please review the updated documentation for more information.</p></li></ul></section><section class="module-features-grid"><h2>Funktionen</h2><div class="features-grid"><div class="feature-card"><div class="feature-icon">◆</div><h3>Real-Time Sync</h3><p>Extend functionality with community-built add-ons.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Role Management</h3><p>Control who can access what.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Offline Mode</h3><p>Roll back to any previous version at any time.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Bulk Import</h3><p>Collaborate with your entire team seamlessly.</p></div><div class="feature-card"><div class="feature-icon">◆</div><h3>Two-Factor Auth</h3><p>Narrow down results with intelligent filtering.</p></div></div></section>"`;
